# === REQUIRED ===
DATABASE_URL=postgresql+asyncpg://soteria:soteria123@localhost:5432/soteria_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-256-bit-secret-key-here-change-this-in-production
ENVIRONMENT=development
ALLOWED_ORIGINS=https://app.soteria.in,https://admin.soteria.in

# === OPTIONAL (mock fallback if missing) ===
OWM_API_KEY=
WAQI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# === ML CONFIGURATION ===
ML_MODEL_DIR=./ml/models
ML_RETRAIN_HOUR=2
ML_RANDOM_STATE=42
ML_N_ESTIMATORS=200
ML_MAX_DEPTH=8
ML_MIN_SAMPLES_LEAF=20

# === ACTUARIAL LIMITS ===
BCR_WARNING_THRESHOLD=0.75
BCR_SUSPEND_THRESHOLD=0.85
BCR_CRITICAL_THRESHOLD=1.00

# === FRONTEND ===
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development
