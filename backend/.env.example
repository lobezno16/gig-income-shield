# === CORE APP CONFIG ===
DATABASE_URL=postgresql+asyncpg://soteria:soteria123@localhost:5432/soteria_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-with-a-minimum-32-character-secret-key
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173

# === MULTI-ORACLE API KEYS (OPTIONAL, MOCK FALLBACK ENABLED) ===
OWM_API_KEY=
WAQI_API_KEY=
CPCB_API_KEY=
CPCB_BASE_URL=https://api.cpcb.gov.in
TOMTOM_API_KEY=
TOMTOM_BASE_URL=https://api.tomtom.com/traffic/services/4

# === PAYOUT GATEWAY (TEST/SANDBOX) ===
PAYMENT_PROVIDER=razorpay_test
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# === TRIGGER ENGINE ===
TRIGGER_POLL_INTERVAL_MINUTES=10
TRIGGER_DEDUPE_MINUTES=60
DEFAULT_WORKER_SHIFT_START=8
DEFAULT_WORKER_SHIFT_END=23

# === ML CONFIGURATION ===
ML_MODEL_DIR=./ml/models
ML_RETRAIN_HOUR=2
ML_RANDOM_STATE=42
ML_N_ESTIMATORS=200
ML_MAX_DEPTH=8
ML_MIN_SAMPLES_LEAF=20

# === ACTUARIAL LIMITS ===
BCR_WARNING_THRESHOLD=0.75
BCR_SUSPEND_THRESHOLD=0.85
BCR_CRITICAL_THRESHOLD=1.00

# === RUNTIME ===
AUTO_SEED=true
WEB_CONCURRENCY=2
WEB_TIMEOUT=120
